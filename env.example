# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=PilgrimCompare

# Supabase Configuration (London eu-west-2 region)
# Get these from your Supabase project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Prisma / Database
# Connection pooling (Supabase connection pooler — use for Prisma client)
DATABASE_URL="postgresql://postgres.[project]:[password]@aws-0-eu-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct connection (no pooler — use for migrations)
DIRECT_URL="postgresql://postgres.[project]:[password]@db.[project].supabase.co:5432/postgres"

# Service Role Key (server-only, never expose to client)
# Used for admin operations that bypass RLS
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Feature Flags
# When true, the app uses Prisma + Postgres (Supabase) for persistence.
# When false (default in dev), the app uses MockDB (in-memory, no DB needed).
# Production deployments should set this to true.
# Tests always use MockDB regardless of this flag.
FEATURE_USE_REAL_DB=false

# Site URL
# Used for JSON-LD structured data, sitemap, and canonical URLs.
# Set to your production domain (e.g. https://pilgrimcompare.co.uk).
NEXT_PUBLIC_SITE_URL=https://pilgrimcompare.co.uk

# Upstash Redis (rate limiting)
# Required in production — in-memory fallback is unsafe for serverless.
# Get these from https://console.upstash.com → create a Redis database → REST API tab.
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# API Configuration (for future use)
# API_BASE_URL=
# API_KEY=

# Authentication (for future use)
# NEXTAUTH_SECRET=
# NEXTAUTH_URL=

# CMS (for future use)
# CONTENTFUL_SPACE_ID=
# CONTENTFUL_ACCESS_TOKEN=

# Analytics (for future use)
# GOOGLE_ANALYTICS_ID=
# FACEBOOK_PIXEL_ID=